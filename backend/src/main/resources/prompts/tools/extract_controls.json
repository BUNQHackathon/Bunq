{
  "name": "extract_controls",
  "description": "Extract internal controls from a bank policy document chunk. A control is a concrete technical or procedural measure a bank takes to enforce a policy. Must be grounded in the document text. Call this tool exactly once with the structured list of controls you extracted.",
  "input_schema": {
    "type": "object",
    "properties": {
      "controls": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "control_type": {"type": "string", "enum": ["technical", "organizational", "procedural"]},
            "category": {"type": "string", "enum": ["preventive", "detective", "corrective"]},
            "description": {"type": "string"},
            "evidence_type": {"type": "string"},
            "implementation_status": {"type": "string", "enum": ["planned", "in_progress", "implemented", "unclear"]},
            "source_text_snippet": {"type": "string"},
            "extraction_confidence": {"type": "number"}
          },
          "required": ["control_type", "category", "description", "source_text_snippet", "extraction_confidence"]
        }
      }
    },
    "required": ["controls"]
  }
}
